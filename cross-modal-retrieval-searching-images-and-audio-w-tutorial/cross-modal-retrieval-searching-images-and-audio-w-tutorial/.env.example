# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_api_key_here

# Optional: For self-hosted RushDB instances, uncomment and set your URL
# RUSHDB_URL=https://your-rushdb-instance.com/api/v1

# Neo4j Aura Connection (required for vector indexes)
# Get your connection URI from Neo4j Aura dashboard
NEO4J_URI=neo4j+s://your-neo4j-uri.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
