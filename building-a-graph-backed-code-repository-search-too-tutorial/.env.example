# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_api_key_here

# Optional: Self-hosted RushDB URL (uncomment if using self-hosted)
# RUSHDB_URL=https://your-self-hosted-host/api/v1

# Embedding model for semantic search
# Options: 'sentence-transformers' (local, free) or 'openai' (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=sentence-transformers

# For OpenAI embeddings (if using EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_key_here
