# RushDB API Key (required)
# Get yours at https://app.rushdb.com
RUSHDB_API_KEY=your_rushdb_api_key_here

# Optional: Custom RushDB URL (for self-hosted deployments)
# RUSHDB_URL=https://your-custom-host/api/v1

# Optional: Sentence transformer model (defaults to all-MiniLM-L6-v2)
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
