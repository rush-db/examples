# RushDB Configuration
# Get your API key from https://app.rushdb.com
RUSHDB_API_KEY=your_rushdb_api_key_here

# Optional: For self-hosted RushDB instances
RUSHDB_URL=https://your-rushdb-instance.com/api/v1

# Embedding Model
# Using all-MiniLM-L6-v2 - fast, lightweight, good quality
# 384-dimensional embeddings, 6x faster than BERT-base
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Time-Decay Configuration
# Lambda controls decay rate: 0.1 = moderate decay, 0.3 = fast decay
DECAY_LAMBDA=0.1

# Memory Search Parameters
MAX_MEMORIES_TO_RETRIEVE=10
SEMANTIC_SIMILARITY_THRESHOLD=0.5
