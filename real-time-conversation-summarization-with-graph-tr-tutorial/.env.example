# RushDB API Key (get one at https://rushdb.com)
RUSHDB_API_KEY=your_api_key_here

# Optional: Custom RushDB instance URL (for self-hosted)
# RUSHDB_URL=https://your-instance.com/api/v1

# Embedding model (sentence-transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector index dimensions (all-MiniLM-L6-v2 produces 384-dim vectors)
VECTOR_DIMENSIONS=384
