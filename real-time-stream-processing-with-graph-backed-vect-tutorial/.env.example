# RushDB Configuration
# Get your API key from: https://app.rushdb.com/dashboard
RUSHDB_API_KEY=your_api_key_here

# Optional: Self-hosted RushDB URL (uncomment if using self-hosted)
# RUSHDB_URL=https://your-rushdb-instance.com/api/v1

# Stream Processing Configuration
STREAM_BATCH_SIZE=10
STREAM_DELAY_MS=100
STREAM_TOTAL_EVENTS=100

# Embedding Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
