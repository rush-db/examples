# RushDB Configuration
RUSHDB_API_KEY=your_api_key_here

# Optional: Custom RushDB URL (for self-hosted)
# RUSHDB_URL=https://your-instance.rushdb.com/api/v1

# Embedding Configuration
# Set to 'managed' for server-side embeddings, 'external' for client-side
EMBEDDING_SOURCE=external

# Embedding dimensions (for all-MiniLM-L6-v2)
EMBEDDING_DIMENSIONS=384
