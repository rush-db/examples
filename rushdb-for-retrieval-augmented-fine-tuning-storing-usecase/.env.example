# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_api_key_here

# Optional: For self-hosted RushDB instances
RUSHDB_URL=https://api.rushdb.com

# Optional: Sentence-transformers model for embeddings
# Default: all-MiniLM-L6-v2 (384 dimensions, fast and accurate)
# Alternatives: all-mpnet-base-v2 (768 dimensions, higher quality)
EMBEDDING_MODEL=all-MiniLM-L6-v2
