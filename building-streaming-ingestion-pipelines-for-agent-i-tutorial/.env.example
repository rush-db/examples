# RushDB Configuration
# Get your API token from https://app.rushdb.com/settings/api-keys
RUSHDB_API_TOKEN=your_api_token_here

# Optional: For self-hosted RushDB instances
# RUSHDB_URL=https://your-self-hosted-instance.com/api/v1

# Pipeline Configuration
# Number of events to batch before writing to RushDB
BATCH_SIZE=10

# Delay between events in the simulator (seconds)
STREAM_DELAY=0.1

# Number of events to generate in demo mode
DEMO_EVENT_COUNT=50

# Number of sessions to seed for historical data
SEED_SESSION_COUNT=5
