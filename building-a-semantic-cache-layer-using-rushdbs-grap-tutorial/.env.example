# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_rushdb_api_key_here

# Optional: Custom RushDB URL (for self-hosted deployments)
# RUSHDB_URL=https://your-custom-domain.com/api/v1

# OpenAI Configuration (for embeddings)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Use local embeddings (no API key needed)
# Set to "local" to use SentenceTransformers instead of OpenAI
EMBEDDING_PROVIDER=openai

# Cache Configuration
# Default time-to-live for cache entries in seconds
DEFAULT_TTL_SECONDS=3600

# Similarity threshold for cache hits (0.0 to 1.0)
SIMILARITY_THRESHOLD=0.90

# Maximum similar entries to link to when storing new entries
MAX_SIMILAR_LINKS=5
