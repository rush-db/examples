# RushDB Configuration
# Get your API key from: https://dash.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_rushdb_api_key_here

# RushDB Self-hosted URL (optional, leave empty for cloud)
# RUSHDB_URL=https://your-host/api/v1

# OpenAI API Key (for generating embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Model
# Using text-embedding-3-small for cost efficiency (1536 dimensions)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
