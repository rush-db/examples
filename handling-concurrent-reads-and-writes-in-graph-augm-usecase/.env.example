# RushDB API Key (get one at https://rushdb.com)
RUSHDB_API_KEY=your_api_key_here

# Optional: Custom self-hosted URL (uncomment if using self-hosted)
# RUSHDB_URL=https://your-instance.rushdb.com/api/v1

# Embedding model (optional, defaults to sentence-transformers/all-MiniLM-L6-v2)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
