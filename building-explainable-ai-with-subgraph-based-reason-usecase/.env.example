# RushDB API credentials
# Get your API key from https://app.rushdb.com
RUSHDB_API_KEY=your_api_key_here

# Optional: Embedding model to use
# Options: all-MiniLM-L6-v2 (default, fast), all-mpnet-base-v2 (more accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: OpenAI API key (if using OpenAI embeddings instead of local)
# OPENAI_API_KEY=your_openai_key_here
