# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_rushdb_api_key_here

# RushDB API URL (optional - defaults to cloud)
# RUSHDB_URL=https://api.rushdb.com/api/v1

# OpenAI API Key (for LLM integration)
OPENAI_API_KEY=your_openai_api_key_here

# Model for embeddings (optional - defaults to text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cache TTL in seconds (optional - defaults to 3600)
CACHE_TTL_SECONDS=3600

# Enable debug logging (optional)
DEBUG=false
