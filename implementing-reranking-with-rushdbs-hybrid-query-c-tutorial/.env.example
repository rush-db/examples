# RushDB Configuration
# Get your API key from https://dash.rushdb.com
RUSHDB_API_KEY=your_api_key_here

# RushDB API endpoint (optional, defaults to cloud)
RUSHDB_URL=https://api.rushdb.com/api/v1

# Optional: Use OpenAI for embeddings instead of local transformers
# OPENAI_API_KEY=your_openai_key_here
# EMBEDDING_PROVIDER=openai

# Optional: Custom embedding model (for local transformers)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
