# RushDB Configuration
# Get your token from: https://app.rushdb.com -> Project Settings -> API Tokens
RUSHDB_API_TOKEN=rdbt_your_project_token_here

# Optional: Set for OpenAI embeddings (uses sentence-transformers if not set)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: RushDB self-hosted URL (defaults to cloud)
# RUSHDB_URL=https://your-self-hosted.rushdb.com/api/v1
