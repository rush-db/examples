# RushDB Configuration
# Get your API key at https://app.rushdb.com
RUSHDB_API_KEY=your_api_key_here

# Optional: Self-hosted RushDB URL (uncomment if using self-hosted)
# RUSHDB_URL=https://your-instance.com/api/v1

# Embedding Model Settings
# Default: all-MiniLM-L6-v2 (384 dimensions, fast)
# Alternative: all-mpnet-base-v2 (768 dimensions, more accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Graph Pruning Settings
PRUNING_THRESHOLD=0.5
CANDIDATE_CHUNK_LIMIT=20
FINAL_CHUNK_LIMIT=5

# Benchmark Settings
BENCHMARK_QUERIES=10
