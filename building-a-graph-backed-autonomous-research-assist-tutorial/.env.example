# RushDB Configuration
# Get your API key from https://app.rushdb.com
RUSHDB_API_TOKEN=your_rushdb_api_key_here

# Optional: Custom RushDB URL for self-hosted instances
# RUSHDB_URL=https://your-host/api/v1

# Embedding Model Configuration
# Set to "local" for sentence-transformers, or "openai" for OpenAI embeddings
EMBEDDING_PROVIDER=local

# For OpenAI embeddings (if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here

# Local embedding model (used when EMBEDDING_PROVIDER=local)
# Smaller models are faster; 384 dims works well for most use cases
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
