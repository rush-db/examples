# RushDB Configuration
# Get your API key from https://app.rushdb.com/settings/api-keys
RUSHDB_API_KEY=your_rushdb_api_key_here

# RushDB Self-hosted URL (leave empty for cloud)
RUSHDB_URL=https://your-instance.rushdb.com/api/v1

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for the LLM demo
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens for LLM input context
MAX_CONTEXT_TOKENS=1500
